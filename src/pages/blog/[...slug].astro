---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);

  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={`${post.data.title} — ignaulin.blog`}>
  <article>
    <h1>{post.data.title}</h1>
    <time datetime={post.data.date.toISOString()}>
      {post.data.date.toLocaleDateString('pt-BR')}
    </time>
    {post.data.tags.length > 0 && (
      <ul class="tags">
        {post.data.tags.map((tag) => (
          <li>#{tag}</li>
        ))}
      </ul>
    )}
    <div class="content">
      <Content />
    </div>
  </article>

  <style>
    article time {
      color: var(--muted);
      font-size: 14px;
    }

    .tags {
      list-style: none;
      display: flex;
      gap: 8px;
      padding: 0;
      margin: 8px 0 0;
    }

    .tags li {
      color: var(--accent);
      font-size: 14px;
    }

    .content {
      margin-top: 32px;
      line-height: 1.7;
    }

    .content :global(img) {
      max-width: 100%;
      border-radius: 8px;
    }

    .content :global(a) {
      color: var(--accent);
    }

    .content :global(pre) {
      overflow-x: auto;
      padding: 16px;
      border-radius: 8px;
      background: #161616;
    }
  </style>
</BaseLayout>
